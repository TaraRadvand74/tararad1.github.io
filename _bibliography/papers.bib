@article{radvand2026trainingfree,
  title = {A Training-free Method for LLM Text Attribution},
  author = {Radvand, Tara and Abdolmaleki, Mojtaba and Mostagir, Mohamed and Tewari, Ambuj},
  year = {2026},
  journal = {arXiv preprint},
  doi = {10.48550/arXiv.2501.02406},
  html = {https://arxiv.org/abs/2501.02406},
  code = {https://github.com/TaraRadvand74/llm-text-detection},
  website = {https://huggingface.co/spaces/tararad/Liketropy-LLM-Detector},
  selected = {true},
  abstract = {Verifying the provenance of content is crucial for educational institutions, social media platforms, firms, and other organizations. As LLM-generated text becomes almost indistinguishable from human-generated content, we design zero-shot statistical tests to distinguish text generated by different known sets of LLMs and to identify whether text was generated by a known LLM or an unknown source. We prove that Type I and Type II errors decrease exponentially with text length, extend the theory to black-box access via sampling, and validate the method numerically under adversarial post-editing.},
  additional_info = {<p><em>Previous title: Zero-shot Statistical Tests for LLM-Generated Text Detection using Finite Sample Concentration Inequalities.</em></p><details><summary>Awards</summary><strong>Award:</strong> Empowering Research with AI Award 2026 ($1,000), AI Institutes at Michigan (AIIM).<br><strong>Award:</strong> Best Presentation Award at MSSISS 2025.<br><strong>Grant:</strong> Ross Doctoral Grant for experiment extension ($4,000).</details><details><summary>Media</summary><a href="https://news.umich.edu/u-m-researchers-devise-tool-for-detecting-ai-that-scores-high-on-accuracy-low-on-false-accusations/">Michigan News</a><br><a href="https://michiganross.umich.edu/news/michigan-ross-research-team-creates-ai-detection-tool">Ross News</a><br><a href="https://www.linkedin.com/posts/wimldsparis_this-weeks-paper-who-wrote-this-zero-shot-activity-7285981721320161280-0rnK">Paris Women in Machine Learning and Data Science Weekly Captures</a></details><details><summary>Presentations</summary>MSOM SIG-Day - Technology, Innovation, and Entrepreneurship (TIE), Harvard Business School, 2026.<br>Revenue Management and Pricing (RMP) Conference, Michigan Ross, 2026.<br>Revenue Management and Pricing (RMP) Conference, Columbia University, 2025.<br>MSSISS Conference [Invited], University of Michigan, 2025.</details>}
}

@unpublished{abdolmaleki2023ride,
  title = {Dynamic Joint Pricing and Empty Relocation Policies for Ride-Sourcing Systems},
  author = {Abdolmaleki, Mojtaba and Chao, Xiuli and Radvand, Tara and Yin, Yafeng},
  year = {2023},
  note = {Working paper},
  doi = {10.2139/ssrn.4210834},
  html = {https://papers.ssrn.com/sol3/papers.cfm?abstract_id=4210834},
  abstract = {We develop a provably near-optimal dynamic pricing and empty vehicle relocation mechanism for a ride-sourcing system with limited customer patience. We model the system as a network of double-ended queues, establish a fluid limit in a large market regime, and develop a simple dynamic policy based on the fluid solution. The policy nearly achieves the fluid upper bound and balances supply utilization and customer waiting times.}
}

@article{radvand2022curbing,
  title = {Curbing Cruising-as-Substitution-For-Parking in Automated Mobility},
  author = {Radvand, Tara and Bahrami, Sina and Yin, Yafeng and Laberteaux, Ken},
  year = {2022},
  journal = {Transportation Research Part C: Emerging Technologies},
  volume = {143},
  pages = {103853},
  doi = {10.1016/j.trc.2022.103853},
  html = {https://www.sciencedirect.com/science/article/abs/pii/S0968090X22002728},
  abstract = {This study considers dynamic parking management in the era of driving automation. Users of privately owned automated vehicles may choose between outside parking, on-street parking, and cruising-as-substitution-for-parking. The paper models these parking choices and their congestion effects, and studies dynamic time-based tolling and parking provision policies.},
  additional_info = {<details><summary>Presentations</summary>TRB Peer-reviewed Conference [Invited Poster], 2022.<br>INFORMS Annual Meeting, Anaheim, 2021.</details><details><summary>Funding</summary>National Science Foundation (CMMI-1904575) and Toyota Motor Engineering & Manufacturing North America (TMNA).</details>}
}

